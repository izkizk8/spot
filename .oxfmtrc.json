{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "crlf",
  "ignorePatterns": [
    ".agents/**",
    "node_modules/**",
    ".git/**",
    ".github/**",
    ".expo/**",
    ".specify/**",
    "android/**",
    "assets/**",
    "dist/**",
    "docs/**",
    "build/**",
    "coverage/**",
    "speckit/**",
    "specs/**",
    "web-build/**",
    "**/*.md",
    "test-results/**",
    "expo-env.d.ts",
    "pnpm-lock.yaml",
    "skills-lock.json"
  ],
  "insertFinalNewline": true,
  "jsxSingleQuote": true,
  "printWidth": 100,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false
}
