{
  "name": "spot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.cjs",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "ios:ipa": "eas build --platform ios --profile sideload --non-interactive",
    "ios:ipa:dev": "eas build --platform ios --profile sideload-dev --non-interactive",
    "ios:simulator": "eas build --platform ios --profile development --non-interactive",
    "altstore:source": "node ./scripts/altstore/build-source.js",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint:ox": "oxlint -c oxlint.json --deny-warnings .",
    "lint:hooks": "eslint --max-warnings 0 \"src/**/*.{js,jsx,ts,tsx}\" \"test/**/*.{js,jsx,ts,tsx}\"",
    "lint": "pnpm lint:ox && pnpm lint:hooks",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "check": "pnpm format:check && pnpm lint && pnpm docs:check && pnpm typecheck && pnpm test",
    "docs:check": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-docs.ps1"
  },
  "dependencies": {
    "@expo/config-plugins": "~55.0.8",
    "@expo/ui": "^55.0.13",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "expo": "~55.0.19",
    "expo-apple-authentication": "^55.0.13",
    "expo-audio": "~55.0.14",
    "expo-calendar": "~55.0.14",
    "expo-camera": "^55.0.16",
    "expo-clipboard": "^55.0.13",
    "expo-constants": "~55.0.15",
    "expo-contacts": "^55.0.13",
    "expo-dev-client": "^55.0.30",
    "expo-device": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.9",
    "expo-image-picker": "^55.0.19",
    "expo-linking": "~55.0.14",
    "expo-local-authentication": "~55.0.13",
    "expo-location": "~55.1.8",
    "expo-notifications": "^55.0.22",
    "expo-quick-actions": "^6.0.1",
    "expo-router": "~55.0.13",
    "expo-secure-store": "^55.0.13",
    "expo-sensors": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-speech": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-task-manager": "^55.0.15",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-ble-plx": "^3.5.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-health": "^1.19.0",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "10.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "jest": "29.7.0",
    "jest-expo": "55.0.16",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.0"
  }
}
