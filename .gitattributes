# Normalize text files to CRLF in the working tree.
* text=auto eol=crlf

# Binary assets must never be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.icns binary
*.pdf binary
*.zip binary
*.ipa binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
